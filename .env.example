# Pick ONE of these providers. The app auto-detects which one is set.

# ── Option A (recommended, free, no credit card needed) ─────────────
# Google Gemini via AI Studio — generous free tier.
# Get a key in ~30 seconds at: https://aistudio.google.com/apikey
GOOGLE_GENERATIVE_AI_API_KEY=

# ── Option B (paid, but supports any model) ─────────────────────────
# Vercel AI Gateway — $5 free credit on signup, routes to OpenAI/Anthropic/etc.
# Get a key at: https://vercel.com/dashboard → AI Gateway → API Keys
# AI_GATEWAY_API_KEY=

# ── Optional: override the default model ────────────────────────────
# Defaults: gemini-2.5-flash (Google) or openai/gpt-5-mini (Gateway)
# AI_MODEL=gemini-2.5-flash
# AI_CHAT_MODEL=gemini-2.5-flash
